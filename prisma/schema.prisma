// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Enum pour les pages de l'application
enum Page {
  HOME
  CONTACTS
  ASSOCIATION
  MEMBERSHIP
  SHOP
  DONATION
}

// Enum pour les sections spécifiques
enum Section {
  // Page Home
  CAROUSEL
  PRESENTATION
  POLE
  PARTNER
  EVENT
  REVIEW
  PRODUCT
  ACHIEVEMENT
  VOLUNTEER

  
  // Page Pôles
  POLE_HERO
  POLE_EVENTS
  POLE_SERVICES
  
  // Page Association
  PRESIDENT
  ABOUT_US
  ACTIVITY_REPORTS
  TEAM
  
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
}

model Image {
  id          String   @id @default(cuid())
  title       String?  // Titre de l'image
  description String?  // Description optionnelle
  url         String   // URL ou chemin de l'image
  alt         String?  // Texte alternatif pour l'accessibilité
  page        Page     // Page où l'image est utilisée
  section     Section  // Section spécifique de la page
  order       Int?     @default(0) // Ordre d'affichage dans la section
  width       Int?     // Largeur en pixels
  height      Int?     // Hauteur en pixels
  size        Int?     // Taille du fichier en bytes
  format      String?  // Format de l'image (jpg, png, webp, etc.)
  isActive    Boolean  @default(true) // Si l'image est active/visible
  metadata    Json?    // Métadonnées supplémentaires (ex: exif, tags, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations optionnelles
  poleId      String?  // Si l'image est liée à un pôle spécifique
  eventId     Int?     // Si l'image est liée à un événement spécifique
  productId   String?  // Si l'image est liée à un produit spécifique

  @@index([page, section])
  @@index([isActive])
  @@index([poleId])
  @@index([eventId])
  @@index([productId])
  @@map("images")
}

model Video  {
  id          String   @id @default(cuid())
  url         String   // URL ou chemin de la vidéo
  title       String?  // Titre de la vidéo
  description String?  // Description optionnelle
  thumbnail   String?  // URL de l'image de prévisualisation
  page        Page     // Page où la vidéo est utilisée
  section     Section  // Section spécifique de la page
  order       Int?     @default(0) // Ordre d'affichage dans la section
  duration    Int?     // Durée en secondes
  size        Int?     // Taille du fichier en bytes
  format      String?  // Format de la vidéo (mp4, webm, etc.)
  isActive    Boolean  @default(true) // Si la vidéo est active/visible
  autoplay    Boolean  @default(false) // Si la vidéo doit être en autoplay
  loop        Boolean  @default(false) // Si la vidéo doit être en boucle
  muted       Boolean  @default(true) // Si la vidéo doit être muette par défaut
  metadata    Json?    // Métadonnées supplémentaires (ex: résolution, codec, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations optionnelles
  poleId      String?  // Si la vidéo est liée à un pôle spécifique
  eventId     Int?     // Si la vidéo est liée à un événement spécifique
  productId   String?  // Si la vidéo est liée à un produit spécifique

  @@index([page, section])
  @@index([isActive])
  @@index([poleId])
  @@index([eventId])
  @@index([productId])
  @@map("videos")
}

model WelcomeSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  reasons     Reason[] // Raisons de la section

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("welcome_sections")
}

model Reason {
  id          String   @id @default(cuid())
  title       String   // Titre de la raison
  icon        String?  // Icone de la raison
  color       String?  // Couleur de la raison
  order       Int      @default(0) // Ordre d'affichage
  isActive    Boolean  @default(true) // Si la raison est actif
  welcomeSectionId String?  // ID de la section d'accueil

  // Relations
  welcomeSection WelcomeSection? @relation(fields: [welcomeSectionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("reasons")
}

model PoleSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  poles       Pole[] // Pôles de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("pole_sections")
}

model Pole {
  id          String   @id @default(cuid())
  name        String   // Nom du pôle
  description String?  // Description du pôle
  imageId     String?  // ID de l'image principale du pôle
  poleSectionId String?  // ID de la section de pôle
  detailsPoleId String @unique
  /// Slug public (`/poles/{slug}`, `/bureau/poles/{slug}/…`), ex. `demarche-administrative`.
  publicSlug  String?  @unique @map("public_slug")

  // Relations
  poleSection PoleSection? @relation(fields: [poleSectionId], references: [id])
  detailsPole DetailsPole @relation("PoleDetailsLink", fields: [detailsPoleId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("poles")
}

model DetailsPole {
  id          String   @id @default(cuid())
  title       String   // Titre du détail du pôle
  description String?  // Description du détail du pôle
  reason      String?  // Raison du détail du pôle
  imageId     String?  // ID de l'image principale du détail du pôle
  videoId     String?  // ID de la vidéo principale du détail du pôle
  isActive    Boolean  @default(true) // Si le détail du pôle est actif
  /// Contenus éditables depuis le bureau (sections communes page publique).
  aboutSectionText        String? @db.Text
  achievementsSectionText String? @db.Text

  detailsPoleStats DetailsPoleStat[]
  detailsPoleServices DetailsPoleService[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pole Pole? @relation("PoleDetailsLink")

  @@map("details_poles")
}

model DetailsPoleStat {
  id            String @id @default(cuid())
  detailsPoleId String
  label      String
  value      Int
  unit       String? // Unité de la valeur (ex: "personnes", "€", "%)")
  helperText String? // E-KAIDI
  order      Int @default(0)
  isActive    Boolean @default(true)
  
  detailsPole DetailsPole @relation(fields: [detailsPoleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([detailsPoleId, order])
  @@map("details_pole_stats")
}

model DetailsPoleService {
  id            String   @id @default(cuid())
  detailsPoleId String
  title       String
  description String   @db.Text
  icon        String?  // ex: "🤝" (emoji) ou clé d’icône si vous préférez
  order       Int      @default(0)
  isActive    Boolean  @default(true)

  detailsPole DetailsPole @relation(fields: [detailsPoleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([detailsPoleId, order])
  @@map("details_pole_services")
}

model PartnerSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  partners    Partner[] // Partenaires de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("partner_sections")
}

model Partner {
  id          String   @id @default(cuid())
  name        String   // Nom du partenaire
  description String?  // Description du partenaire
  imageId     String?  // ID de l'image principale du partenaire
  url         String?  // URL du partenaire
  published   Boolean  @default(false) // Visible sur le site
  partnerSectionId String?  // ID de la section de partenaires

  // Relations
  partnerSection PartnerSection? @relation(fields: [partnerSectionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("partners")
}

model EventSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  events      Event[] // Événements de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("event_sections")
}

model Event {
  id          String   @id @default(cuid())
  title        String   // Nom de l'événement
  description String?  // Description de l'événement
  imageId     String?  // ID de l'image de couverture (première image)
  videoId     String?  // ID de la vidéo principale de l'événement
  startDate   DateTime // Date de début de l'événement
  endDate     DateTime // Date de fin de l'événement
  location    String?  // Lieu de l'événement
  published   Boolean  @default(false) // Visible sur le site

  eventSectionId String?  // ID de la section d'événement

  // Relations
  eventSection EventSection? @relation(fields: [eventSectionId], references: [id])
  images       EventImage[]  // Galerie d'images de l'événement
  videos       EventVideo[]  // Liens vidéo (YouTube, Vimeo, etc.)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("events")
}

model EventVideo {
  id      String  @id @default(cuid())
  eventId String
  url     String  // URL complète (YouTube, Vimeo, etc.)
  order   Int     @default(0) // Ordre d'affichage

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  @@map("event_videos")
}

model EventImage {
  id      String @id @default(cuid())
  eventId String
  imageId String // Cloudinary public ID
  order   Int    @default(0) // Ordre d'affichage (0 = couverture)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  @@map("event_images")
}

model ReviewSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  reviews     Review[] // Avis de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("review_sections")
}

/// Postes organisationnels (président, secrétaire, bénévole, etc.). Référence stable par `code`.
model Poste {
  id          String   @id @default(cuid())
  code        String   @unique // Ex. PRESIDENT, VOLUNTEER
  labelFr     String   @map("label_fr")
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  persons Person[]
  reviews Review[]

  @@map("postes")
}

/// Rôles d’accès dashboard (Better Auth `User.role` aligné sur `code`).
model Role {
  id          String   @id @default(cuid())
  code        String   @unique // Ex. SUPER-ADMIN, BUREAU
  labelFr     String   @map("label_fr")
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Review {
  id          String    @id @default(cuid())
  firstName   String    // Prénom de la personne
  lastName    String    // Nom de la personne
  posteId     String @map("poste_id") // Poste affiché (table Poste)
  body        String    @db.Text // Contenu du témoignage/avis
  avatarUrl   String?  // URL de l'image de profil
  country     String?  // Pays (ex: "🇬🇳 Guinée" ou "Guinée")
  rating      Int      @default(5) // Note sur 5 étoiles (1-5)
  order       Int      @default(0) // Ordre d'affichage
  isActive    Boolean  @default(true) // Si l'avis est visible
  isVerified  Boolean  @default(false) // Si l'avis est vérifié/modéré
  reviewSectionId String?  // ID de la section d'avis

  // Relations
  reviewSection ReviewSection? @relation(fields: [reviewSectionId], references: [id])
  poste           Poste          @relation(fields: [posteId], references: [id], onDelete: Restrict)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  publishedAt DateTime? // Date de publication (si différente de createdAt)

  @@index([isActive])
  @@index([rating])
  @@index([order])
  @@index([posteId])
  @@map("reviews")
}

model ProductSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  products    Product[] // Produits de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("product_sections")
}

model Product {
  id          String   @id @default(cuid())
  title       String   // Titre du produit
  description String?  // Description du produit
  imageId     String?  // ID de l'image principale du produit
  price       Int      // Prix de base du produit (en centimes)
  stock       Int      // Stock du produit
  isActive    Boolean  @default(true) // Si le produit est actif
  discountActive  Boolean @default(false) // Si la réduction est activée
  discountPercent Int?                    // Pourcentage de réduction (1-99)
  productSectionId String?  // ID de la section de produit
  productCategoryId String?  // ID de la catégorie de produit
  orderId String?  // ID de la commande du produit
  // Relations
  productSection ProductSection? @relation(fields: [productSectionId], references: [id])
  productCategory ProductCategory? @relation(fields: [productCategoryId], references: [id])
  orderItems OrderItem[] // Items de la commande


  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("products")
}

model ProductCategory {
  id          String   @id @default(cuid())
  title       String   // Titre de la catégorie
  description String?  // Description de la catégorie
  products    Product[] // Produits de la catégorie
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("product_categories")
}

model AchievementSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  achievements Achievement[] // Réalisations de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("achievement_sections")
}

model Achievement {
  id          String            @id @default(cuid())
  label       String?           // Label de la valeur (ex: "Étudiants accompagnés")
  value       Int?              // Valeur numérique (pour les statistiques)
  icon        String?           // Emoji ou icône (ex: "🎓", "👥")
  color       String?           // Couleur du thème (red, yellow, green, blue)
  achievementSectionId String?  // ID de la section de réalisation
  // Métadonnées
  order       Int               @default(0) // Ordre d'affichage
  isActive    Boolean           @default(true) // Si la réalisation est visible
  
  // Relations
  achievementSection AchievementSection? @relation(fields: [achievementSectionId], references: [id])

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  publishedAt DateTime?         // Date de publication


  @@index([isActive])
  @@index([order])
  @@map("achievements")
}

model Person {
  id          String   @id @default(cuid())
  firstName   String   // Prénom de la personne
  lastName    String   // Nom de la personne
  email       String?  // Email de la personne
  phone       String   // Numéro de téléphone de la personne
  addressId   String?  // ID de l'adresse de la personne
  userId      String?  @unique // Compte dashboard lié (User Better Auth)
  posteId     String?  @map("poste_id") // Poste organisationnel (table Poste)
  image       String?  // Photo de profil (URL Cloudinary)
  showOnSite  Boolean  @default(true) // Afficher la photo sur le site public
  description String?  // Biographie / description

  donations Donation[] // Donations de la personne
  memberShips MemberShip[] // Cotisations de la personne
  orders Order[] // Commandes de la personne
  payments Payment[] // Paiements de la personne
  beneficiaries Beneficiary[] // Demandes bénéficiaires de la personne
  permanenceAdminPresenceVolunteers PermanenceAdminPresenceVolunteer[] // Présences à la permanence administrative de la personne

  // Relations
  address Address? @relation(fields: [addressId], references: [id])
  paymentHistories PaymentHistory[] // Historiques de paiement de la personne
  poste            Poste?           @relation(fields: [posteId], references: [id], onDelete: SetNull)
  teamMember       TeamMember?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([posteId])
  @@map("persons")
}

model VolunteerSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  volunteers  Volunteer[] // Bénévoles de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("volunteer_sections")
}

model Volunteer {
  id          String   @id @default(cuid())
  personId    String   @unique
  isActive    Boolean  @default(true) // Si le bénévole est actif
  volunteerSectionId String?  // ID de la section de bénévole

  // Relations
  volunteerSection VolunteerSection? @relation(fields: [volunteerSectionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("volunteers")
}

model TeamMemberSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  teamMembers TeamMember[] // Membres de l'équipe de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("team_member_sections")
}

model TeamMember {
  id          String   @id @default(cuid())
  personId    String   @unique
  description String?  // Description du membre de l'équipe
  imageId     String?  // ID de l'image principale du membre de l'équipe
  order       Int      @default(0) // Ordre d'affichage
  showOnSite  Boolean  @default(true) // Affiché dans la section "Notre équipe" du site
  teamMemberSectionId String?  // ID de la section de membre de l'équipe

  // Relations — le poste bureau est sur Person.poste (FK Poste)
  person            Person             @relation(fields: [personId], references: [id], onDelete: Cascade)
  teamMemberSection TeamMemberSection? @relation(fields: [teamMemberSectionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("team_members")
}

model SocialMedia {
  id          String   @id @default(cuid())
  name        String   // Nom du réseau social
  url         String   // URL du réseau social
  icon        String?  // Icone du réseau social
  order       Int      @default(0) // Ordre d'affichage
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("social_medias")
}

model ReportActivitySection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  reports     ReportActivity[] // Rapports d'activité de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("report_activity_sections")
}

model ReportActivity {
  id          String   @id @default(cuid())
  label String?  // Label du rapport
  year        Int      // Année du rapport
  pdfUrl      String   // URL du rapport
  /// Si false, le rapport n’apparaît pas sur la page publique « Notre association ».
  isPublished Boolean  @default(true)
  reportActivitySectionId String?  // ID de la section de rapport d'activité

  // Relations
  reportActivitySection ReportActivitySection? @relation(fields: [reportActivitySectionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("report_activities")
}

model AboutUsSection {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  aboutUs     AboutUs[] // A propos de nous de la section
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("about_us_sections")
}

model AboutUs {
  id          String   @id @default(cuid())
  title       String   // Titre de l'about us
  description String?  // Description de l'about us
  imageId     String?  // ID de l'image principale de l'about us
  aboutUsSectionId String?  // ID de la section de about us

  // Relations
  aboutUsSection AboutUsSection? @relation(fields: [aboutUsSectionId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("about_us")
}

model MemberShip {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  description String?  // Description de la section
  amount      Int      // Prix de la cotisation
  year        Int      // Année de la cotisation
  isActive    Boolean  @default(true) // Si la cotisation est actif
  personId    String
  paymentId   String   @unique // ID du paiement

  // Relations
  person Person? @relation(fields: [personId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("member_ships")
}

model Donation {
  id          String   @id @default(cuid())
  title       String   // Titre de la section
  message String?  // Message de la donation
  amount      Int      // Prix de la donation
  personId    String
  paymentId   String   @unique // ID du paiement

  // Relations
  person Person? @relation(fields: [personId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("donations")
}

model Address {
  id          String   @id @default(cuid())
  address     String   // Adresse de la personne
  city        String   // Ville de la personne
  country     String   // Pays de la personne
  zipCode     String   // Code postal de la personne
  state       String   // État de la personne
  countryCode String   // Code pays de la personne

  person Person[] // Personnes liées à l'adresse

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("addresses")
}

model Contact {
  id        String   @id @default(cuid())
  phone     String   // Numéro de téléphone de l'association
  email     String   // Email de l'association
  address   String   @default("") // Rue et numéro
  city      String   @default("") // Ville
  zipCode   String   @default("") // Code postal

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("contacts")
}

enum PopupType {
  IMAGE_TEXT
  PROSPECTUS
}

model Popup {
  id           String    @id @default(cuid())
  type         PopupType @default(IMAGE_TEXT)
  isActive     Boolean   @default(false)

  // IMAGE_TEXT
  badge        String?
  title        String?
  subtitle     String?
  description  String?
  date         String?
  location     String?
  imageId      String?   // Cloudinary publicId
  ctaLabel     String?
  ctaUrl       String?

  // PROSPECTUS
  prospectusIds String[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@map("popups")
}

model Banner {
  id        String   @id @default(cuid())
  isActive  Boolean  @default(false)
  badge     String?
  title     String
  date      String?
  location  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("banners")
}

enum ContactSubmissionStatus {
  PENDING
  READ
  REPLIED
}

model ContactSubmission {
  id        String                  @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactSubmissionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("contact_submissions")
}

/// Type de demande configurable (libellé, ordre, précision optionnelle obligatoire).
model BeneficiaryDemandType {
  id             String   @id @default(cuid())
  label          String
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  /// Si vrai, le formulaire de suivi exige un champ « précision » (ex. « Autre »).
  requiresDetail Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  beneficiaries Beneficiary[]

  @@map("beneficiary_demand_types")
}

/// Type de document fourni configurable (code stable dans le JSON de la fiche).
model BeneficiaryDocumentType {
  id                  String   @id @default(cuid())
  /// Clé stockée dans `beneficiaries.documentsProvided` (tableau JSON).
  code                String   @unique
  label               String
  sortOrder           Int      @default(0)
  isActive            Boolean  @default(true)
  /// Si coché : précision texte obligatoire pour ce document (ex. « Autre »).
  requiresOtherDetail Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("beneficiary_document_types")
}

/// Fiche Demande bénéficiaire / permanence administrative (ex-Google Form suivi).
model Beneficiary {
  id               String   @id @default(cuid())
  permanenceDate   DateTime @db.Date
  /// Un ou plusieurs types de demande (sélection multiple au formulaire).
  demandTypes      BeneficiaryDemandType[]
  /// Texte libre si au moins un type exige une précision (`requiresDetail`).
  requestDetail    String?
  firstName        String
  lastName         String
  phone            String?
  email            String?
  notes            String?
  /// Données sensibles (mots de passe) : accès base restreint, pas d’exposition côté public.
  birthDate              DateTime? @db.Date
  birthCountry           String?
  birthMunicipality      String?
  fatherName             String?
  motherName             String?
  gmailAccount           String?
  gmailPassword          String?
  ekadiLogin             String?
  ekadiPassword          String?
  /// Tableau JSON de codes `BeneficiaryDocumentType.code`.
  documentsProvided      Json?
  /// Précision si « Autre » document est coché.
  documentOtherDetail    String?
  requestStatus          String?
  statusComment          String?
  assignedResponsibleName String?
  paymentResponsible     String?
  paymentOtherDetail     String?
  submittedByPersonId String?

  person Person? @relation(fields: [submittedByPersonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([permanenceDate])
  @@index([submittedByPersonId])
  @@map("beneficiaries")
}

/// Liste de présence à la permanence administrative (remplace l’ancien Google Form).
model PermanenceAdminPresenceVolunteer {
  id                  String   @id @default(cuid())
  permanenceDate      DateTime @db.Date
  memberFullName      String
  hours               Decimal  @db.Decimal(5, 2)
  comment             String?
  submittedByPersonId   String?

  person Person? @relation(fields: [submittedByPersonId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([permanenceDate])
  @@index([submittedByPersonId])
  @@map("permanence_admin_presence_volunteers")
}

/// Créneaux affichés sur le pôle « Démarche administrative » (synchronisés site + dashboard).
model AdministrativePermanenceSlot {
  id        String   @id @default(cuid())
  slotDate  DateTime @unique @db.Date
  /// Heure locale au format 24h « HH:mm » (ex. 14:00).
  startTime String
  endTime   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slotDate])
  @@map("administrative_permanence_slots")
}

/// Texte libre pour la carte « Horaires » (pôle administratif). Une seule ligne `default`.
model AdministrativePermanenceSettings {
  id               String   @id @default("default")
  /// Si renseigné, remplace le texte généré automatiquement dans la carte Horaires.
  horairesCardText String?  @db.Text
  /// Contrôle l’affichage du bloc « Campus France — votre dossier » sur la page publique.
  showCampusFranceCard Boolean @default(true) @map("show_campus_france_card")
  updatedAt        DateTime @updatedAt

  @@map("administrative_permanence_settings")
}

model Order {
  id          String   @id @default(cuid())
  orderNumber String   // Numéro de la commande
  totalAmount Int      // Montant total de la commande
  paymentId   String   @unique // ID du paiement
  personId    String   

  // Relations
  person Person @relation(fields: [personId], references: [id])
  items OrderItem[] // Items de la commande
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("orders")
}

// Table de jointure pour Order et Product avec quantité
model OrderItem {
  id          String   @id @default(cuid())
  orderId     String   // ID de la commande
  productId   String   // ID du produit
  quantity    Int      // Quantité commandée
  price       Int      // Prix unitaire au moment de la commande (en centimes)
  subtotal    Int      // Sous-total (quantity * price) en centimes
  
  // Relations
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Payment {
  id          String   @id @default(cuid())
  paymentReference String @unique // Référence de paiement Stripe
  amount      Int      // Montant du paiement
  status      PaymentStatus   // Statut du paiement
  type      String   // Type de paiement
  paymentMethod String   // Méthode de paiement
  paymentDate DateTime @default(now()) // Date de paiement
  personId    String

  // Relations
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  orders Order[] // Commandes liées au paiement
  donations Donation[] // Donations liées au paiement
  memberShips MemberShip[] // Adhésions liées au paiement

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("payments")
}

model PaymentHistory {
  id          String   @id @default(cuid())
  paymentId   String   // ID du paiement
  personId    String   // ID de la personne 
  status      PaymentStatus   // Statut du paiement
  type      String   // Type de paiement
  paymentDate DateTime @default(now()) // Date de paiement

  // Relations
  person Person? @relation(fields: [personId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("payment_histories")
}

// ── Better Auth ────────────────────────────────────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  role          String?
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions                           Session[]
  accounts                           Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

/// Dépôt étudiant — démarche Campus France (formulaire public pôle administratif).
model CampuceFranceStudentSubmission {
  id             String   @id @default(cuid())
  firstName      String
  lastName       String
  phone          String
  email          String
  /// Année de dépôt (clé de déduplication métier).
  submissionYear Int
  country        String
  acceptanceCity String
  universitySite String
  academicLevel  String
  program        String
  /// Types d'aide sollicités (plusieurs possibles sur le même dossier).
  helpTypes      String[]
  visaAppointmentDate DateTime? @db.Date
  comment        String? @db.Text
  /// Identifiants Cloudinary (`gam/campuce-france`), jusqu’à 3 fichiers (PDF ou image).
  filesIds String[]
  /// Suivi admin : dossier complet (validation interne).
  isComplete      Boolean  @default(false)
  /// Suivi admin : attestation d'hébergement fournie.
  hasHostingAttestation Boolean @default(false)
  /// Suivi admin : logement trouvé (si aide sollicitée = logement).
  hasHousingFound Boolean @default(false)
  /// Suivi admin : visa obtenu.
  hasVisa Boolean @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([createdAt])
  @@index([submissionYear])
  @@unique([submissionYear, phone, email])
  @@map("campuce_france_student_submissions")
}
